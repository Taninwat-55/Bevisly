# ============================================================
#  Bevisly MVP – Root .gitignore
#  (Covers both Supabase backend + frontend)
# ============================================================

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment / Credentials
.env
.env.local
.env.*.local
.credentials

# Supabase CLI
.supabase/
supabase/.temp/
supabase/.branches/
supabase/.functions-cache/

# Build artifacts
dist/
build/
tmp/
*.log

# Firecrawl research output
.firecrawl/
frontend/.firecrawl/

# System / Editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

.claude/settings.local.json

# Internal project docs (not for public repo)
CLAUDE.md
GROWTH_WEEKLY.md
PRODUCT_ROADMAP.md

# Claude Code tooling (internal AI agent configs)
.agents/
.claude/agents/